{
  "manifest_version": 3,
  "name": "웨일 사이드바 Codex 샘플",
  "version": "0.1.0",
  "description": "Whale Codex 플러그인용 네이버 웨일 사이드바 확장앱 샘플입니다.",
  "minimum_whale_version": "3",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "sidebar_action": {
    "default_page": "sidebar.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Codex 웨일 샘플",
    "use_navigation_bar": true,
    "mobile_user_agent": true
  }
}
